# Port for the Express server (default: 4321)
PORT=4321

# Comma-separated list of tools that require approval before execution
# Default covers the most impactful tools
APPROVAL_TOOLS=Bash,Write,Edit,MultiEdit,NotebookEdit

# SQLite database file path (default: server/dashboard.db)
DB_PATH=./dashboard.db

# MCP request timeout in seconds (default: 300)
MCP_TIMEOUT=300

# Approval polling timeout in seconds (default: 60)
APPROVAL_TIMEOUT=60
